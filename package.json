{
  "name": "velokey",
  "version": "1.0.0",
  "type": "module",
  "author": {
    "name": "Rishabh",
    "email": "rishabh.j.tripathi@gmail.com"
  },
  "license": "Apache-2.0",
  "private": false,
  "scripts": {
    "dev": "next dev --webpack",
    "analyze": "ANALYZE=true npm run build",
    "realtime:dev": "partykit dev",
    "realtime:deploy": "partykit deploy",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check:unused": "knip",
    "audit:lighthouse": "lighthouse http://127.0.0.1:3000 --output=html --output-path=./lighthouse-report.html",
    "prepare": "husky",
    "postinstall": "node -e \"const fs=require('fs');const raw=fs.readFileSync('./node_modules/inspirational-quotes/data/data.json','utf8');fs.mkdirSync('./data',{recursive:true});fs.writeFileSync('./data/quotes.json',JSON.stringify(JSON.parse(raw.replace(/^\\uFEFF/,''))));\" && node scripts/generate-code-data.mjs && node scripts/sync-theme-fonts.mjs && node scripts/sync-theme-accents.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md}": "prettier --write"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@next/third-parties": "^16.2.3",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@serwist/next": "^9.5.7",
    "@tabler/icons-react": "^3.41.1",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "inspirational-quotes": "^2.0.1",
    "lenis": "^1.3.25",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.8.0",
    "merge-stream": "^2.0.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "partykit": "^0.0.115",
    "partysocket": "^1.3.0",
    "postprocessing": "^6.39.3",
    "radix-ui": "^1.4.3",
    "random-words": "^2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "3.8.0",
    "serwist": "^9.5.7",
    "shadcn": "^4.2.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.185.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@react-three/test-renderer": "^9.1.0",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/nextjs-vite": "^10.5.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "lighthouse": "^13.4.0",
    "lint-staged": "^17.1.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.5.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
